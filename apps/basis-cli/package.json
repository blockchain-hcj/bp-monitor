{
  "name": "basis-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env --enable-source-maps dist/index.js",
    "dev": "node --env-file-if-exists=.env --import tsx/esm src/index.ts",
    "build": "tsc -p tsconfig.json",
    "probe": "node --env-file-if-exists=.env --import tsx/esm src/tools/symbolProbe.ts"
  },
  "dependencies": {
    "nats": "^2.29.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
