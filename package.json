{
  "name": "cex-spread-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env --enable-source-maps dist/index.js",
    "dev": "npm run build && node --env-file-if-exists=.env --enable-source-maps dist/index.js",
    "test": "vitest run test/*.test.ts",
    "nats:tail": "tsx src/tools/natsTail.ts"
  },
  "dependencies": {
    "@mysten/deepbook-v3": "^1.1.0",
    "@mysten/sui": "^2.5.0",
    "nats": "^2.29.3",
    "pg": "^8.13.1",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.51.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
